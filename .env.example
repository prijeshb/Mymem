# Copy to .env and fill in values. Never commit .env.

# Required if provider=anthropic
ANTHROPIC_API_KEY=

# Required if provider=openai
OPENAI_API_KEY=

# Extraction eval reference model — pick one provider:
GROQ_API_KEY=          # free tier: console.groq.com  (default)
GEMINI_API_KEY=        # free tier: aistudio.google.com
NVIDIA_API_KEY=        # build.nvidia.com — use for evals (llama-3.3-70b, nemotron)
# MYMEM_EVAL_REFERENCE_PROVIDER=groq   # groq | gemini | nvidia

# Optional: override config.yaml values via environment
# MYMEM_PROVIDER=ollama
# MYMEM_LOG_FORMAT=json
# MYMEM_LOG_LEVEL=DEBUG
